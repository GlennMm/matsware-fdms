// ─────────────────────────────────────────────────────────────────────────
//  6. AWAITING FDMS CONFIRMATION (when you need the receipt ID)
// ─────────────────────────────────────────────────────────────────────────

async Task AwaitConfirmationExample(FdmsService fdms, GetConfigResponse config)
{
    var receipt = BuildSampleInvoice(config);
    var enqueued = await fdms.EnqueueReceiptAsync(receipt);

    // Print receipt immediately — it's already signed
    PrintReceipt(enqueued);

    // Later (or in parallel), wait for FDMS confirmation
    try
    {
        var fdmsResp = await enqueued.SubmissionTask;
        Console.WriteLine($"FDMS confirmed: ID={fdmsResp.ReceiptID} at {fdmsResp.ServerDate}");

        // Store the FDMS receipt ID and server signature in your database
        // await db.UpdateReceiptFdmsData(receipt.ReceiptGlobalNo, fdmsResp.ReceiptID, fdmsResp.ServerDate);
    }
    catch (FdmsApiException ex)
    {
        Console.WriteLine($"FDMS rejected: {ex.ErrorCode} — {ex.Message}");
        // Handle: maybe flag receipt for manual review
    }
}

void PrintReceipt(EnqueuedReceipt enqueued)
{
    var r = enqueued.Receipt;
    Console.WriteLine($"=== FISCAL TAX INVOICE ===");
    Console.WriteLine($"Invoice No: {r.ReceiptCounter}/{r.ReceiptGlobalNo}");
    Console.WriteLine($"Date: {r.ReceiptDate:dd/MM/yyyy HH:mm}");
    foreach (var line in r.ReceiptLines)
        Console.WriteLine($"  {line.ReceiptLineName}  {line.ReceiptLineTotal:F2}");
    Console.WriteLine($"TOTAL: {r.ReceiptCurrency} {r.ReceiptTotal:F2}");
    Console.WriteLine($"Verification: {enqueued.VerificationCode}");
    Console.WriteLine($"QR: {enqueued.QrCodeUrl}");
}

