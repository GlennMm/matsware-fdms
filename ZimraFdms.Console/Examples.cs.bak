// ─────────────────────────────────────────────────────────────────────────
//  2. FIRST-TIME DEVICE REGISTRATION (run once)
// ─────────────────────────────────────────────────────────────────────────

async Task RegisterNewDevice(FdmsService fdms)
{
    // Optional: verify taxpayer info first
    var taxpayer = await fdms.VerifyTaxpayerAsync();
    Console.WriteLine($"Registering to: {taxpayer.TaxPayerName} (TIN: {taxpayer.TaxPayerTIN})");

    // Register — generates keypair, submits CSR, receives certificate
    var result = await fdms.RegisterDeviceAsync(
        privateKeyOutputPath: "certs/device-private.pem",
        certificateOutputPath: "certs/device-cert.pem");

    Console.WriteLine($"Registered! Operation: {result.OperationID}");

    // Then create PFX for mTLS:
    // openssl pkcs12 -export -out device.pfx -inkey device-private.pem -in device-cert.pem
}

// ─────────────────────────────────────────────────────────────────────────
//  3. FULL FISCAL DAY LIFECYCLE
// ─────────────────────────────────────────────────────────────────────────

async Task RunFiscalDay(FdmsService fdms)
{
    // ── Load config ──
    var config = await fdms.GetConfigAsync();
    Console.WriteLine($"Taxpayer: {config.TaxPayerName} | Max day: {config.TaxPayerDayMaxHrs}h");

    // Check certificate expiry
    if (config.CertificateValidTill < DateTime.UtcNow.AddMonths(1))
        Console.WriteLine("⚠ Certificate expiring soon — call RenewCertificateAsync()");

    // ── Check status + open day ──
    var status = await fdms.GetStatusAsync();
    if (status.FiscalDayStatus != FiscalDayStatus.FiscalDayClosed)
    {
        Console.WriteLine($"Day already in state: {status.FiscalDayStatus}");
        return;
    }

    var day = await fdms.OpenDayAsync();
    Console.WriteLine($"Opened fiscal day #{day.Response.FiscalDayNo}");

    // ── Subscribe to queue events (optional) ──
    fdms.OnReceiptSubmitted += (r, resp) =>
        Console.WriteLine($"  ✓ #{r.ReceiptGlobalNo} → FDMS ID {resp.ReceiptID}");
    fdms.OnReceiptFailed += (r, ex) =>
        Console.WriteLine($"  ✗ #{r.ReceiptGlobalNo} FAILED: {ex.Message}");

    // ── Issue receipts ──
    var invoice = BuildSampleInvoice(config);
    var enqueued = await fdms.EnqueueReceiptAsync(invoice);

    // Receipt is immediately printable — no need to wait for FDMS
    Console.WriteLine($"Receipt #{enqueued.Receipt.ReceiptGlobalNo} signed and enqueued");
    Console.WriteLine($"  QR: {enqueued.QrCodeUrl}");
    Console.WriteLine($"  Verification: {enqueued.VerificationCode}");
    Console.WriteLine($"  Queue depth: {fdms.PendingCount}");

    // OPTIONAL: if you need the FDMS response (e.g. for receiptID), await it
    // var fdmsResponse = await enqueued.SubmissionTask;
    // Console.WriteLine($"  FDMS receipt ID: {fdmsResponse.ReceiptID}");

    // Issue a credit note
    var creditNote = BuildSampleCreditNote(config);
    var enqueuedCN = await fdms.EnqueueReceiptAsync(creditNote);
    Console.WriteLine($"Credit note #{enqueuedCN.Receipt.ReceiptGlobalNo} enqueued");

    // Simulate some work time...
    await Task.Delay(3000);

    // ── Close fiscal day ──
    // This drains the queue, signs Z report, submits, and polls for confirmation
    var close = await fdms.CloseDayAsync();
    Console.WriteLine($"Day closed! OK={fdms.SubmittedCount} FAIL={fdms.FailedCount}");
}

// ─────────────────────────────────────────────────────────────────────────
//  4. BUILDING RECEIPTS — helpers
// ─────────────────────────────────────────────────────────────────────────

ReceiptDto BuildSampleInvoice(GetConfigResponse config)
{
    var vat15 = config.ApplicableTaxes.FirstOrDefault(t => t.TaxPercent == 15);
    var taxId = vat15?.TaxID ?? 1;

    return new ReceiptDto
    {
        ReceiptType = ReceiptType.FiscalInvoice,
        ReceiptCurrency = "USD",
        InvoiceNo = $"INV-{DateTime.Now:yyyyMMdd}-001",
        ReceiptDate = DateTime.Now,
        ReceiptLinesTaxInclusive = true,
        ReceiptLines = new List<ReceiptLineDto>
        {
            new()
            {
                ReceiptLineType = ReceiptLineType.Sale,
                ReceiptLineNo = 1,
                ReceiptLineHSCode = "64039190",
                ReceiptLineName = "School Shoes — Size 6",
                ReceiptLinePrice = 25.00,
                ReceiptLineQuantity = 2,
                ReceiptLineTotal = 50.00,
                TaxCode = "A", TaxPercent = 15, TaxID = taxId
            },
            new()
            {
                ReceiptLineType = ReceiptLineType.Sale,
                ReceiptLineNo = 2,
                ReceiptLineHSCode = "48201000",
                ReceiptLineName = "Exercise Book 96-page (x10)",
                ReceiptLinePrice = 1.50,
                ReceiptLineQuantity = 10,
                ReceiptLineTotal = 15.00,
                TaxCode = "A", TaxPercent = 15, TaxID = taxId
            }
        },
        ReceiptTaxes = new List<ReceiptTaxDto>
        {
            new()
            {
                TaxCode = "A", TaxPercent = 15, TaxID = taxId,
                TaxAmount = Math.Round(65.00 * 15.0 / 115.0, 2), // 8.48
                SalesAmountWithTax = 65.00
            }
        },
        ReceiptPayments = new List<PaymentDto>
        {
            new() { MoneyTypeCode = MoneyType.Cash, PaymentAmount = 65.00 }
        },
        ReceiptTotal = 65.00,
        ReceiptPrintForm = ReceiptPrintForm.Receipt48,
        BuyerData = new BuyerDto
        {
            BuyerRegisterName = "John Moyo",
            BuyerTIN = "1234567890"
        },
        UserInfo = new UserInfoDto
        {
            Username = "cashier01",
            UserFullName = "Tendai Nyathi"
        }
    };
}

ReceiptDto BuildSampleCreditNote(GetConfigResponse config)
{
    var vat15 = config.ApplicableTaxes.FirstOrDefault(t => t.TaxPercent == 15);
    var taxId = vat15?.TaxID ?? 1;

    return new ReceiptDto
    {
        ReceiptType = ReceiptType.CreditNote,
        ReceiptCurrency = "USD",
        InvoiceNo = $"CN-{DateTime.Now:yyyyMMdd}-001",
        ReceiptDate = DateTime.Now,
        ReceiptNotes = "Returned 1x School Shoes — wrong size",
        ReceiptLinesTaxInclusive = true,
        CreditDebitNote = new CreditDebitNoteDto
        {
            DeviceID = 12345,
            ReceiptGlobalNo = 1,
            FiscalDayNo = 1
        },
        ReceiptLines = new List<ReceiptLineDto>
        {
            new()
            {
                ReceiptLineType = ReceiptLineType.Sale,
                ReceiptLineNo = 1,
                ReceiptLineHSCode = "64039190",
                ReceiptLineName = "School Shoes — Size 6",
                ReceiptLinePrice = -25.00,
                ReceiptLineQuantity = 1,
                ReceiptLineTotal = -25.00,
                TaxCode = "A", TaxPercent = 15, TaxID = taxId
            }
        },
        ReceiptTaxes = new List<ReceiptTaxDto>
        {
            new()
            {
                TaxCode = "A", TaxPercent = 15, TaxID = taxId,
                TaxAmount = Math.Round(-25.00 * 15.0 / 115.0, 2), // -3.26
                SalesAmountWithTax = -25.00
            }
        },
        ReceiptPayments = new List<PaymentDto>
        {
            new() { MoneyTypeCode = MoneyType.Cash, PaymentAmount = -25.00 }
        },
        ReceiptTotal = -25.00,
        ReceiptPrintForm = ReceiptPrintForm.Receipt48
    };
}

