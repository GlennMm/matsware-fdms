    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>ZimraFdms</RootNamespace>
    <AssemblyName>ZimraFdms</AssemblyName>
    <Description>General-purpose ZIMRA Fiscal Device Gateway API integration library for .NET</Description>
